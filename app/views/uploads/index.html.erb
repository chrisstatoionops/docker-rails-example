<div class="px-3 sm:px-0 py-8">
  <h1 class="text-2xl font-semibold text-gray-900 mb-2">Upload files</h1>
  <p class="text-gray-600 mb-6">
    Files are stored with Active Storage
    <% if ENV["S3_BUCKET"].present? && ENV["S3_BUCKET"] != "unused" %>
      in S3 bucket <span class="font-mono text-gray-800"><%= ENV["S3_BUCKET"] %></span>.
    <% else %>
      on local disk (set <span class="font-mono">S3_BUCKET</span> to use S3).
    <% end %>
  </p>

  <% if notice.present? %>
    <p class="mb-4 text-green-700 bg-green-50 border border-green-200 rounded-md px-3 py-2"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="mb-4 text-red-700 bg-red-50 border border-red-200 rounded-md px-3 py-2"><%= alert %></p>
  <% end %>

  <%= form_with model: @upload, url: uploads_path, multipart: true, class: "mb-10 flex flex-wrap items-end gap-3" do |f| %>
    <div>
      <%= f.label :file, "Choose file", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.file_field :file, required: true, class: "block w-full text-sm text-gray-900 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-gray-200 file:text-gray-800 hover:file:bg-gray-300" %>
    </div>
    <div>
      <%= f.submit "Upload", class: "inline-flex justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-gray-700 hover:bg-gray-800 cursor-pointer" %>
    </div>
  <% end %>

  <h2 class="text-lg font-medium text-gray-900 mb-3">Your uploads</h2>

  <% if @uploads.empty? %>
    <p class="text-gray-500">No files yet.</p>
  <% else %>
    <div class="overflow-x-auto border border-gray-200 rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Size</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Uploaded</th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Download</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @uploads.each do |upload| %>
            <% next unless upload.file.attached? %>
            <tr>
              <td class="px-4 py-3 text-sm text-gray-900"><%= upload.file.filename %></td>
              <td class="px-4 py-3 text-sm text-gray-600"><%= number_to_human_size(upload.file.byte_size) %></td>
              <td class="px-4 py-3 text-sm text-gray-600"><%= l(upload.created_at, format: :short) %></td>
              <td class="px-4 py-3 text-sm text-right">
                <%= link_to "Download", upload_path(upload), class: "text-gray-700 underline hover:text-gray-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
